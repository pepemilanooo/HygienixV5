{
  "name": "hygienix-v5",
  "version": "5.0.0",
  "private": true,
  "description": "HYGIENIX V5 - SaaS Pest Control Management System",
  "scripts": {
    "dev:api": "cd apps/api && npm run dev",
    "dev:web": "cd apps/web && npm run dev",
    "dev:all": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "build": "npm run build:api && npm run build:web",
    "build:api": "cd apps/api && npm run build",
    "build:web": "cd apps/web && npm run build",
    "db:push": "cd apps/api && npx prisma db push",
    "db:migrate": "cd apps/api && npx prisma migrate dev",
    "db:seed": "cd apps/api && npx ts-node prisma/seed.ts",
    "db:studio": "cd apps/api && npx prisma studio",
    "test": "cd apps/api && npm test",
    "postinstall": "cd apps/api && npx prisma generate"
  },
  "workspaces": ["apps/*"],
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  },
  "engines": { "node": ">=18.0.0" }
}
